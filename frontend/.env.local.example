# ─── HunterFit Frontend — Variáveis de Ambiente ────────────────────────────
# Copie este arquivo para .env.local e preencha os valores

# URL base do backend .NET
NEXT_PUBLIC_API_URL=http://localhost:5000

# Supabase (para auth direto se necessário)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=seu-anon-key-aqui

# Cloudflare R2 (URLs de storage)
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-XXXX.r2.dev

# Strava OAuth (clientId só — secret fica no backend)
NEXT_PUBLIC_STRAVA_CLIENT_ID=seu-client-id

# Sentry (opcional)
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
