{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=hunterfit;Username=postgres;Password=YOUR_PASSWORD"
  },
  "Jwt": {
    "Key": "REPLACE_WITH_256BIT_SECRET_KEY_MINIMUM_32_CHARS",
    "Issuer": "HunterFit",
    "Audience": "HunterFitUsers"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://hunterfit.vercel.app"
    ]
  },
  "Gemini": {
    "ApiKey": "YOUR_GEMINI_API_KEY"
  },
  "Strava": {
    "ClientId": "YOUR_STRAVA_CLIENT_ID",
    "ClientSecret": "YOUR_STRAVA_CLIENT_SECRET"
  },
  "Cloudflare": {
    "R2Bucket": "hunterfit-media",
    "AccountId": "YOUR_CF_ACCOUNT_ID",
    "ApiToken": "YOUR_CF_API_TOKEN"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
